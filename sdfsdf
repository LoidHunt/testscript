local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local sensitivity = 0.3
local angleX = 0
local angleY = 0
local lastMousePos = nil
local CAMERA_DISTANCE = 8
local CAMERA_HEIGHT = 2

RunService.RenderStepped:Connect(function()
    local character = player.Character
    if not character then return end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local mousePos = UserInputService:GetMouseLocation()

    if lastMousePos then
        local delta = mousePos - lastMousePos
        if delta.Magnitude > 0 and delta.Magnitude < 100 then
            angleX = angleX - delta.X * sensitivity
            angleY = math.clamp(angleY - delta.Y * sensitivity, -60, 60)
        end
    end
    lastMousePos = mousePos

    local rootPos = root.Position + Vector3.new(0, CAMERA_HEIGHT, 0)

    local offset = CFrame.new(rootPos)
        * CFrame.Angles(0, math.rad(angleX), 0)
        * CFrame.Angles(math.rad(angleY), 0, 0)
        * CFrame.new(0, 0, CAMERA_DISTANCE)

    camera.CameraType = Enum.CameraType.Scriptable
    camera.CFrame = CFrame.new(offset.Position, rootPos)
end)
