local orderMap = {
    ["Fizzly is my favorite drink. Gimme that please."] = "MountainDew",
    ["Hey pizza person. Give me a pepperoni pizza/Hi"] = "PepperoniPizza",
    ["OMG the sausage pizza looks heavenly! I'll have that./Amazed"] = "SausagePizza",
}

local function getProductFromResponse(response)
    if orderMap[response] then return orderMap[response] end
    local lower = response:lower()
    if lower:find("fizzly") or lower:find("mountain") or lower:find("dew") then return "MountainDew"
    elseif lower:find("pepperoni") then return "PepperoniPizza"
    elseif lower:find("sausage") then return "SausagePizza"
    elseif lower:find("cheese") then return "CheesePizza"
    end
    return nil
end

local function getRegister()
    for i = 1, 5 do
        local reg = workspace:FindFirstChild("Register" .. i)
        if reg then return reg end
    end
    return nil
end

local function solveCustomer(customer)
    local head = customer:FindFirstChild("Head")
    if not head then return end

    local dialogSimple = head:FindFirstChild("DialogSimple")
    if not dialogSimple then return end

    local correctChoice = dialogSimple:FindFirstChild("Correct")
    if not correctChoice then return end

    local response = correctChoice.ResponseDialog
    local product = getProductFromResponse(response)

    if not product then
        warn("⚠️ Неизвестный товар: " .. tostring(response))
        return
    end

    local register = getRegister()
    if not register then warn("Регистр не найден!") return end

    local button = register:FindFirstChild("Button" .. product)
    if not button then warn("Кнопка не найдена: Button" .. product) return end

    -- Шаг 1: кликнуть на пузырь
    workspace:WaitForChild("Dialog"):FireServer("ClickedBubble", head)
    task.wait(0.3)

    -- Шаг 2: TutorialService
    workspace:WaitForChild("TutorialService")
        :WaitForChild("PlayerAction"):FireServer("ClickedBubble", true)
    task.wait(0.3)

    -- Шаг 3: выбрать правильный ответ
    workspace:WaitForChild("Dialog"):FireServer("ResponseSelected", correctChoice, head)
    task.wait(0.3)

    -- Шаг 4: анимации
    workspace:WaitForChild("Animation"):WaitForChild("AnimationStopped"):FireServer("Hi")
    task.wait(0.1)
    workspace:WaitForChild("Animation"):WaitForChild("AnimationStarted"):FireServer("Hi")
    task.wait(0.4)

    -- Шаг 5: нажать кнопку товара
    workspace:WaitForChild("GameService")
        :WaitForChild("RegisterButtonPressedNoCustomer")
        :FireServer(product, button)

    print("✅ " .. customer.Name .. " -> " .. product)
end

local function autoSolveAll()
    local customers = workspace:FindFirstChild("Customers")
    if not customers then warn("Папка Customers не найдена!") return end

    for _, customer in ipairs(customers:GetChildren()) do
        if customer:FindFirstChild("Head") then
            task.spawn(solveCustomer, customer)
            task.wait(0.5)
        end
    end
end

autoSolveAll()

workspace:WaitForChild("Customers").ChildAdded:Connect(function(customer)
    task.wait(1)
    solveCustomer(customer)
end)
